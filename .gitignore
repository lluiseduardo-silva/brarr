# Cargo build output
/target
**/*.rs.bk

# Runtime data
*.log
*.pid

# Local orchestrator SQLite (created on first run; see BRARR_DB_PATH)
brarr.db
brarr.db-shm
brarr.db-wal

# Local config / segredos (tokens de tracker, etc.)
.env
.env.*
!.env.example
config.local.toml

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Coverage / profiling
*.profraw
*.profdata
tarpaulin-report.html
cobertura.xml
config.toml

# Session checkpoints (handoff notes between Claude Code sessions)
CHECKPOINT.md
CHECKPOINT-*.md
tmp_*.py

# Claude Code per-project config (preview server launch, etc.)
.claude/

# Local rule fixtures used to test the profile editor — operator-
# specific drafts, not source. Keep them out of source control.
*-rule.json
*-rules.json

# Tailwind standalone binary (per-platform; install via scripts/install-tailwind.{sh,ps1})
/tools/

# Compiled CSS bundle — generated by scripts/build-css.{sh,ps1}; Docker
# build stage re-runs the compile so production images don't depend on a
# committed artifact going stale.
/crates/brarr-orchestrator/static/app.css
