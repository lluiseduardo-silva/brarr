# brarr — sample environment file for `docker-compose.yml`.
#
# Copy this to `.env` next to `docker-compose.yml`, fill at least
# BRARR_AUTH_TOKEN, and `docker compose up -d`.
#
# Every variable below has a sensible default baked into the image —
# uncomment + set only what you need to override.

# ────────────────────────────────────────────────────────────────
# REQUIRED
# ────────────────────────────────────────────────────────────────

# Opaque admin token. The admin UI redirects to /login until a
# request presents this in the `brarr_session` cookie; the gRPC
# service requires `Authorization: Bearer <token>` metadata.
# Generate with: `openssl rand -hex 32`
BRARR_AUTH_TOKEN=replace-me-with-openssl-rand-hex-32

# ────────────────────────────────────────────────────────────────
# Image
# ────────────────────────────────────────────────────────────────

# Override to pin a specific release (e.g. v0.1.0). Default = latest.
# BRARR_IMAGE_TAG=latest

# ────────────────────────────────────────────────────────────────
# Network
# ────────────────────────────────────────────────────────────────

# Host port mapping for the admin UI / gRPC. Change if 3000 / 50051
# clash with something else on the host. Inside the container the
# binds always use 3000 / 50051.
# BRARR_HTTP_HOST_PORT=3000
# BRARR_GRPC_HOST_PORT=50051

# Bind addresses inside the container — only change if you proxy
# differently. Defaults already accept connections from any source.
# BRARR_HTTP_ADDR=0.0.0.0:3000
# BRARR_GRPC_ADDR=0.0.0.0:50051

# Public URL the orchestrator stamps into its Torznab outbound feed's
# `<enclosure url>` (so Sonarr / Radarr can grab the proxied release).
# Set to whatever URL your reverse proxy exposes to the outside world.
# BRARR_PUBLIC_URL=https://brarr.example/

# ────────────────────────────────────────────────────────────────
# Storage
# ────────────────────────────────────────────────────────────────

# Host directory holding WASM plugin files (referenced by provider
# rows with `plugin_path`). Defaults to ./plugins next to the compose
# file. Path is mounted read-only inside the container.
# BRARR_PLUGINS_DIR=./plugins

# Internal sqlite path. Change only if you remount /data.
# BRARR_DB_PATH=/data/brarr.db

# Internal static asset directory. Change only if you swap the
# bundled CSS / JS for a fork.
# BRARR_STATIC_DIR=/static

# Named Docker volume that holds the sqlite DB. Useful if you run
# multiple brarr instances on the same host and need to disambiguate.
# BRARR_DATA_VOLUME=brarr-data

# ────────────────────────────────────────────────────────────────
# Auto-push poller
# ────────────────────────────────────────────────────────────────

# Cycle between `*arr/wanted` polls, in seconds. 1800 = 30 min,
# matches Sonarr's default RSS sync. Lower it for testing; raise it
# if your trackers rate-limit aggressively.
# BRARR_ARR_POLL_INTERVAL_SECS=1800

# ────────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────────

# `tracing-subscriber` filter — see https://docs.rs/tracing-subscriber
# Examples:
#   info                              (default — quiet, just info+ lines)
#   debug                             (everything)
#   brarr_orchestrator=debug,info     (debug only the orchestrator crate)
# RUST_LOG=info

# Set to 1 for stack traces in panics. Costs nothing in steady state.
# RUST_BACKTRACE=0
